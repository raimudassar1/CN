  "minimal_pairs_drills": [
    {
      "id": "b_vs_p",
      "title": "b vs p — Aspiration",
      "instruction": "b has NO puff of air. p HAS a strong puff. Hold your hand in front of your mouth and feel the difference.",
      "pairs": [
        {
          "a": "bā (八)",
          "b": "pā (趴)",
          "a_meaning": "eight",
          "b_meaning": "to lie face down"
        },
        {
          "a": "bó (伯)",
          "b": "pó (婆)",
          "a_meaning": "uncle",
          "b_meaning": "old woman/grandma"
        },
        {
          "a": "bǐ (比)",
          "b": "pǐ (匹)",
          "a_meaning": "to compare",
          "b_meaning": "(classifier for horses)"
        }
      ]
    },
    {
      "id": "zh_vs_z",
      "title": "zh vs z — Tongue position",
      "instruction": "zh: curl tongue back. z: tongue stays flat near front teeth. This is one of the hardest distinctions for English speakers.",
      "pairs": [
        {
          "a": "zhī (知)",
          "b": "zī (茲)",
          "a_meaning": "to know",
          "b_meaning": "(suffix/here)"
        },
        {
          "a": "zhù (住)",
          "b": "zù (租)",
          "a_meaning": "to live/reside",
          "b_meaning": "to rent"
        },
        {
          "a": "zhǎo (找)",
          "b": "zǎo (早)",
          "a_meaning": "to look for",
          "b_meaning": "early/morning"
        }
      ]
    },
    {
      "id": "x_vs_sh",
      "title": "x vs sh — Tongue position",
      "instruction": "x: tongue near front teeth, flat. sh: tongue curled back. x sounds lighter and higher-pitched.",
      "pairs": [
        {
          "a": "xiā (蝦)",
          "b": "shā (沙)",
          "a_meaning": "shrimp",
          "b_meaning": "sand"
        },
        {
          "a": "xīn (心)",
          "b": "shēn (身)",
          "a_meaning": "heart",
          "b_meaning": "body"
        },
        {
          "a": "xiū (修)",
          "b": "shōu (收)",
          "a_meaning": "to repair",
          "b_meaning": "to receive"
        }
      ]
    },
    {
      "id": "n_vs_l",
      "title": "n vs l — Nasal vs Lateral",
      "instruction": "n: air flows through the nose. l: tongue touches the roof and air flows around the sides.",
      "pairs": [
        {
          "a": "nǐ (你)",
          "b": "lǐ (裡)",
          "a_meaning": "you",
          "b_meaning": "inside"
        },
        {
          "a": "nán (南)",
          "b": "lán (藍)",
          "a_meaning": "south",
          "b_meaning": "blue"
        },
        {
          "a": "nǎi (奶)",
          "b": "lǎi (來—variant)",
          "a_meaning": "milk/grandma",
          "b_meaning": "to come"
        }
      ]
    }
  ],
  "tone_sandhi_rules": [
    {
      "rule": "Two Third Tones Together",
      "description": "When two 3rd tone syllables appear together, the first one changes to 2nd tone.",
      "formula": "3 + 3 → 2 + 3",
      "examples": [
        {
          "written": "你好",
          "spoken_pinyin": "ní hǎo",
          "note": "你 (nǐ→ní) + 好 (hǎo)"
        },
        {
          "written": "可以",
          "spoken_pinyin": "ké yǐ",
          "note": "可 (kě→ké) + 以 (yǐ)"
        },
        {
          "written": "也好",
          "spoken_pinyin": "yé hǎo",
          "note": "也 (yě→yé) + 好 (hǎo)"
        }
      ]
    },
    {
      "rule": "一 (yī) Tone Change",
      "description": "The number 一 changes tone depending on what follows it.",
      "formula": "一 before 4th tone → 2nd tone; before 1st/2nd/3rd → 4th tone",
      "examples": [
        {
          "written": "一個",
          "spoken_pinyin": "yí gè",
          "note": "一 + 4th tone gè → 一 becomes yí"
        },
        {
          "written": "一天",
          "spoken_pinyin": "yì tiān",
          "note": "一 + 1st tone tiān → 一 becomes yì"
        },
        {
          "written": "一起",
          "spoken_pinyin": "yì qǐ",
          "note": "一 + 3rd tone → 一 becomes yì"
        }
      ]
    },
    {
      "rule": "不 (bù) Tone Change",
      "description": "不 is 4th tone, but before another 4th tone it becomes 2nd tone.",
      "formula": "不 + 4th tone → bú + 4th tone",
      "examples": [
        {
          "written": "不是",
          "spoken_pinyin": "bú shì",
          "note": "不 + 是(shì/4th) → bú"
        },
        {
          "written": "不去",
          "spoken_pinyin": "bú qù",
          "note": "不 + 去(qù/4th) → bú"
        },
        {
          "written": "不好",
          "spoken_pinyin": "bù hǎo",
          "note": "不 + 好(hǎo/3rd) → stays bù"
        }
      ]
    }
  ],

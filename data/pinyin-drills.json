    {
      "number": 3,
      "name": "Third Tone",
      "description": "Falling then rising — like saying 'really?' with deep doubt",
      "symbol": "ǎ",
      "contour": "214",
      "color": "#e67e22",
      "tip": "Dip down low then come back up. In fast speech it often just falls low.",
